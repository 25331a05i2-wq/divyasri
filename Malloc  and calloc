#include <stdio.h>
#include <stdlib.h>
int main() {
    int n, i;
    int *m_ptr, *c_ptr;
Printf(“25331A05I2\n”);
    printf("Enter number of elements: ");
    scanf("%d", &n);
    m_ptr = (int*) malloc(n * sizeof(int));
    printf("\nEnter elements for malloc array:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &m_ptr[i]);
    }
    printf("Elements using malloc:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", m_ptr[i]);
    }
    c_ptr = (int*) calloc(n, sizeof(int));
    printf("\n\nEnter elements for calloc array:\n");
    for(i = 0; i < n; i++) {
        scanf("%d", &c_ptr[i]);
    }
    printf("Elements using calloc:\n");
    for(i = 0; i < n; i++) {
        printf("%d ", c_ptr[i]);
    }
    free(m_ptr);
    free(c_ptr);
    return 0;
}
