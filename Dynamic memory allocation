#include <stdio.h>
#include <stdlib.h>
int main() {
    int *ptr, n, i, new_size;
Printf(“25331A05I2\n”);
    printf("Enter number of elements: ");
    scanf("%d", &n);
    ptr = (int *)malloc(n * sizeof(int));
    if (ptr == NULL) {
        printf("Memory allocation failed\n");
        return 0;
    }
    printf("Enter %d elements:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", ptr + i);
    }
    printf("Original elements are:\n");
    for (i = 0; i < n; i++) {
        printf("%d ", *(ptr + i));
    }
    printf("\nEnter new size: ");
    scanf("%d", &new_size);
    ptr = (int *)realloc(ptr, new_size * sizeof(int));
    if (ptr == NULL) {
        printf("Reallocation failed\n");
        return 0;
    }
    printf("Enter %d new elements:\n", new_size);
    for (i = 0; i < new_size; i++) {
        scanf("%d", ptr + i);
    }
    printf("New elements are:\n");
    for (i = 0; i < new_size; i++) {
        printf("%d ", *(ptr + i));
    }
    free(ptr);
    return 0;
}
